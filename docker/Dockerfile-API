# ================================= API ================================
FROM python:3.8-alpine AS cmdb-api

LABEL description="Python3.8,cmdb"

WORKDIR /data/apps/cmdb

# 先复制依赖文件，利用Docker缓存
COPY cmdb-api/requirements.txt .

# 配置Alpine源并安装系统依赖
# 注：根据部署踩坑记录，国内网络环境下需要使用稳定的镜像源
# 当前阿里云Alpine源v3.20可能存在不稳定问题，先尝试使用官方源
RUN apk add --no-cache tzdata gcc musl-dev libffi-dev openldap-dev python3-dev jpeg-dev zlib-dev build-base || \
    (sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories && \
    apk add --no-cache tzdata gcc musl-dev libffi-dev openldap-dev python3-dev jpeg-dev zlib-dev build-base)

# 安装Python依赖（只有requirements.txt变化时才重新安装）
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY cmdb-api /data/apps/cmdb

# 配置settings.py
RUN if [ -f settings.example.py ]; then \
        cp settings.example.py settings.py && \
        sed -i "s#{user}:{password}@127.0.0.1:3306/{db}#cmdb:123456@cmdb-db:3306/cmdb#g" settings.py && \
        sed -i "s#redis://127.0.0.1#redis://cmdb-cache#g" settings.py && \
        sed -i "s#CACHE_REDIS_HOST = '127.0.0.1'#CACHE_REDIS_HOST = 'cmdb-cache'#g" settings.py && \
        echo "Settings configured successfully"; \
    else \
        echo "settings.example.py not found!"; \
        ls -la; \
    fi

ENV TZ=Asia/Shanghai

ADD https://github.com/ufoscout/docker-compose-wait/releases/download/2.7.3/wait /wait
RUN chmod +x /wait

CMD ["sh", "-c", "/wait && flask run --host=0.0.0.0 --port=5000"]